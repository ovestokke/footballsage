# FootballSage configuration
# Copy to .env and fill in your keys.

# --- Web / Docker ---
# Public port for the web app.
WEB_PORT=3000

# Browser-facing API base. Keep /api for same-origin Next.js proxy.
NEXT_PUBLIC_API_BASE_URL=/api

# Internal API URL for Next.js server-side proxy.
# Compose sets this automatically; only override for custom setups.
# API_INTERNAL_URL=http://api:8000

# CORS origins. Only relevant if exposing FastAPI directly.
CORS_ORIGINS=*

# --- Dev only ---
# Enable uvicorn --reload in compose.dev.yaml/manual dev.
# Do not use for normal Docker production-style runs.
#API_RELOAD=1
#API_PORT=8000

# --- Sage LLM (required for AI advice) ---
SAGE_LLM_PROVIDER=openrouter
SAGE_LLM_MODEL=deepseek/deepseek-v4-flash

# Pick one:
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: vision model for screenshot OCR.
# SAGE_OCR_LLM_MODEL=google/gemini-3-flash-preview
