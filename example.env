# FootballSage – Sage LLM configuration
# Copy this file to .env and fill in your keys.
#
# Sage advice endpoint (required):
SAGE_LLM_PROVIDER=openrouter
SAGE_LLM_MODEL=deepseek/deepseek-v4-flash
# SAGE_LLM_MODEL=anthropic/claude-sonnet-4.5
# SAGE_LLM_MODEL=openai/gpt-5-mini

# Pick the API key for your chosen provider:
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: separate vision model for screenshot OCR.
# When omitted but OpenRouter is the provider, google/gemini-3-flash-preview is used automatically.
# SAGE_OCR_LLM_MODEL=google/gemini-3-flash-preview
# SAGE_OCR_LLM_MODEL=openai/gpt-4o-mini
